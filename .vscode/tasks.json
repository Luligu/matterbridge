      "args": ["--inspect=0.0.0.0:9229", "./bin/matterbridge.js", "--debug", "--trace", "--loader"],
      "problemMatcher": [],
      "detail": "Start Matterbridge with Node inspector on 0.0.0.0:9229 (debug/trace/loader)."
    },
    {
