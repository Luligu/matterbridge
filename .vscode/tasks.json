{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run: Default",
      "type": "process",
      "command": "node",
      "args": ["./bin/matterbridge.js"],
      "problemMatcher": [],
      "detail": "Start Matterbridge (default mode)."
    },
    {
      "label": "Run: Bridge",
      "type": "process",
      "command": "node",
      "args": ["./bin/matterbridge.js", "--bridge", "--port", "5540"],
      "problemMatcher": [],
      "detail": "Start Matterbridge in bridge mode on port 5540."
    },
    {
      "label": "Run: Childbridge",
      "type": "process",
      "command": "node",
      "args": ["./bin/matterbridge.js", "--childbridge", "--port", "5540"],
      "problemMatcher": [],
      "detail": "Start Matterbridge in childbridge mode on port 5540."
    },
    {
      "label": "Run: Controller",
      "type": "process",
      "command": "node",
      "args": ["./bin/matterbridge.js", "--controller", "--frontend", "0", "--port", "6000"],
      "problemMatcher": [],
      "detail": "Start Matterbridge in controller mode on port 6000 with frontend disabled."
    },
    {
      "label": "Run: Controller Pair",
      "type": "process",
      "command": "node",
      "args": ["./bin/matterbridge.js", "--controller", "--frontend", "0", "--port", "6000", "--pair", "--pairingcode", "32902218933"],
      "problemMatcher": [],
      "detail": "Start controller mode and run pairing using pairing code 32902218933."
    },
    {
      "label": "Run: Controller Discover",
      "type": "process",
      "command": "node",
      "args": ["./bin/matterbridge.js", "--controller", "--frontend", "0", "--port", "6000", "--discover"],
      "problemMatcher": [],
      "detail": "Start controller mode and run device discovery."
    },
    {
      "label": "Run: Controller Unpair All",
