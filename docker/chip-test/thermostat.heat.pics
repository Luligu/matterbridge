# To run phyton tests on Thermostat --PICS is required
TSTAT.S=1
TSTAT.S.F00=1 # Heating
TSTAT.S.F01=0 # Cooling
TSTAT.S.F05=0 # Auto mode
TSTAT.S.F08=0 # Presets
TSTAT.S.F02=0 # Occupancy
TSTAT.S.A0003=1 # AbsMinHeatSetpointLimit
TSTAT.S.A0004=1 # AbsMaxHeatSetpointLimit
TSTAT.S.A0012=1 # OccupiedHeatingSetpoint
TSTAT.S.A0015=1 # MinHeatSetpointLimit
TSTAT.S.A0016=1 # MaxHeatSetpointLimit
TSTAT.S.A0019=1 # MinSetpointDeadBand
