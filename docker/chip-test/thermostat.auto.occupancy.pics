# To run phyton tests on Thermostat --PICS is required
TSTAT.S=1
TSTAT.S.F00=1 # Heating
TSTAT.S.F01=1 # Cooling
TSTAT.S.F05=1 # Auto mode
TSTAT.S.F08=0 # Presets
TSTAT.S.F02=1 # Occupancy
TSTAT.S.A0000=1 # LocalTemperature
TSTAT.S.A0001=1 # OutdoorTemperature
TSTAT.S.A0002=1 # Occupancy
TSTAT.S.A0003=1 # AbsMinHeatSetpointLimit
TSTAT.S.A0004=1 # AbsMaxHeatSetpointLimit
TSTAT.S.A0005=1 # AbsMinCoolSetpointLimit
TSTAT.S.A0006=1 # AbsMaxCoolSetpointLimit
TSTAT.S.A0011=1 # OccupiedCoolingSetpoint
TSTAT.S.A0012=1 # OccupiedHeatingSetpoint
TSTAT.S.A0013=1 # UnoccupiedCoolingSetpoint
TSTAT.S.A0014=1 # UnoccupiedHeatingSetpoint
TSTAT.S.A0015=1 # MinHeatSetpointLimit
TSTAT.S.A0016=1 # MaxHeatSetpointLimit
TSTAT.S.A0017=1 # MinCoolSetpointLimit
TSTAT.S.A0018=1 # MaxCoolSetpointLimit
TSTAT.S.A0019=1 # MinSetpointDeadBand
TSTAT.S.A001B=1 # ControlSequenceOfOperation
TSTAT.S.A001C=1 # SystemMode
TSTAT.S.A001E=1 # ThermostatRunningMode
