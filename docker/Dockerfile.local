# ─────────────── BUILD STAGE ───────────────
FROM node:24-trixie-slim AS builder

# 🛠️ Set noninteractive frontend
ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /matterbridge
COPY . .
RUN \
  npm ci --no-fund --no-audit && \
  node scripts/sync-workspaces.mjs --scope @matterbridge && \
  node scripts/bundle-workspaces.mjs --scope @matterbridge && \
  npm run buildProduction && \
  cd apps/frontend && npm ci --no-fund --no-audit && npm run build && cd ../.. && \
  npm link --no-fund --no-audit && \
  npm --workspaces --include-workspace-root pkg delete devDependencies scripts && \
  rm -rf .cache .devcontainer .git .github .vscode docker docs node_modules reflector screenshots scripts systemd package-lock.json npm-shrinkwrap.json && \
  npm install --no-fund --no-audit --omit=dev && \
  npm shrinkwrap && \
  npm pack

