# Build context ignore rules for docker/Dockerfile.local.bun ONLY.
#
# BuildKit automatically uses this file instead of the repo-root .dockerignore
# when the build targets this Dockerfile (`-f docker/Dockerfile.local.bun`).
# It fully replaces the root .dockerignore (no merge).
#
# Like Dockerfile.local.node, the bun image builds Matterbridge from local source, so
# it keeps src/, packages/ and apps/. It does not read git, chip or scripts.

# Not needed by the bun build (saves ~150 MB of context)
.agents
.claude
.codex
.devcontainer
.env
.git
.github
**/buntest
chip
docker
!docker/Dockerfile.local.bun
!docker/Dockerfile.local.bun.dockerignore
!docker/entrypoint.local.bun.sh
docs
reflector
screenshots
scripts
!scripts/bun-exports.mjs
systemd
**/vitest
*.md

# Dependencies
**/node_modules/

# Test output
**/coverage/

# Build output (rebuilt inside the image)
**/dist/
**/build/
**/*.tsbuildinfo

# Tooling caches
**/.cache/

# VS Code settings
**/.vscode/

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# Other assets not needed for builds
.gitignore
.gitattributes
.gitlocalignore
CODEOWNERS
.oxlintrc*.*
.oxfmtrc*.*
tsconfig*.json
packages/**/tsconfig*.json
**/package-lock.json
vite.config.ts
docker-downloads-history.json
**/tmp/
**/temp/
**/jest/
**/*.tgz
