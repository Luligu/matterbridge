{
  "name": "@matterbridge/frontend",
  "version": "3.5.1",
  "description": "Matterbridge frontend application",
  "author": "https://github.com/Luligu",
  "license": "Apache-2.0",
  "homepage": "https://matterbridge.io/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Luligu/matterbridge.git",
    "directory": "apps/frontend"
  },
  "bugs": {
    "url": "https://github.com/Luligu/matterbridge/issues"
  },
  "funding": {
    "type": "buymeacoffee",
    "url": "https://www.buymeacoffee.com/luligugithub"
  },
  "keywords": [
    "matterbridge",
    "homebridge",
    "bridge",
    "plugin",
    "frontend",
    "matter.js",
    "matter-node.js",
    "matter",
    "matterprotocol",
    "iot",
    "smarthome",
    "connectedthings",
    "hap",
    "homekit",
    "siri",
    "google-home",
    "alexa",
    "homeassistant",
    "smartthings",
    "ewelink"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.19.0 <21.0.0 || >=22.13.0 <23.0.0 || >=24.0.0 <25.0.0 || >=26.0.0 <27.0.0"
  },
  "files": [
    "build",
    "package.json",
    "npm-shrinkwrap.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:debug": "vite build --mode debug",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "lint": "oxlint --config .oxlintrc.json --max-warnings 0 --type-check --type-aware --report-unused-disable-directives-severity warn",
    "lint:fix": "oxlint --config .oxlintrc.json --max-warnings 0 --type-check --type-aware --report-unused-disable-directives-severity warn --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest --reporter verbose",
    "test:verbose": "vitest run --reporter verbose",
    "test:coverage": "vitest run --reporter verbose --coverage",
    "clean": "node ../../scripts/clean.mjs",
    "cleanBuild": "npm run clean && npm run build",
    "deepClean": "node ../../scripts/deep-clean.mjs",
    "reset": "npm run deepClean && npm run softReset",
    "softReset": "npm install --no-fund --no-audit && npm prune --no-fund --no-audit && npm run build && npm run typecheck",
    "checkDependencies": "npm install --no-fund --no-audit --no-save npm-check-updates && ncu --reject @mui/* && npm run softReset",
    "updateDependencies": "npm install --no-fund --no-audit --no-save npm-check-updates && ncu -u --reject @mui/* && npm run softReset",
    "runMeBeforePublish": "npm run format && npm run lint && npm run build && npm run typecheck && npm run test",
    "prepublishOnly": "npm run cleanBuild && npm pkg delete devDependencies scripts && node ../../scripts/prepublish-clean.mjs && npm install --no-fund --no-audit --omit=dev && npm shrinkwrap --omit=dev"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@mui/icons-material": "7.3.10",
    "@mui/material": "7.3.10",
    "@rjsf/core": "6.6.2",
    "@rjsf/utils": "6.6.2",
    "@rjsf/validator-ajv8": "6.6.2",
    "notistack": "3.0.2",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "vite": "8.1.0",
    "vitest": "4.1.9",
    "@typescript/native-preview": "7.0.0-dev.20260626.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "oxlint-tsgolint": "0.23.0"
  }
}
