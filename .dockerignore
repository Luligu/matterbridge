# General docker build context ignore rules

# Not needed by the local build (saves ~150 MB of context)
.agents
.claude
.devcontainer
.env
.git
.github
chip
docker
docs
reflector
screenshots
scripts
systemd
**/vitest
*.md

# Dependencies
**/node_modules/

# Test output
**/coverage/

# Build output (rebuilt inside the image)
**/dist/
**/build/
**/*.tsbuildinfo

# Tooling caches
**/.cache/

# VS Code settings
**/.vscode/

# Logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/pnpm-debug.log*

# Other assets not needed for builds
docker-downloads-history.json
**/tmp/
**/temp/
**/jest/
**/*.tgz
**/*.zip
