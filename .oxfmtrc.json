{
  "printWidth": 180,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "quoteProps": "consistent",
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "requirePragma": false,
  "insertPragma": false,
  "proseWrap": "preserve",
  "endOfLine": "lf",
  "embeddedLanguageFormatting": "off",
  "singleAttributePerLine": false,
  "sortPackageJson": false,
  "ignorePatterns": ["**/.cache/", "**/.git/", "**/coverage/", "**/dist/", "**/build/", "**/jest/", "**/node_modules/", "**/temp/", "**/*.html", "apps/"]
}
