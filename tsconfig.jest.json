{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "noEmit": true,
    "composite": false,
    "incremental": false,
    "isolatedModules": true
  },
  "include": ["**/src/**/*.spec.ts", "**/src/**/*.test.ts", "**/src/**/__test__/**/*.ts", "**/test/**/*.spec.ts", "**/test/**/*.test.ts", "**/test/**/__test__/**/*.ts"],
  "exclude": []
}
